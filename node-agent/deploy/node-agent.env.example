# Copy to /etc/node-agent/node-agent.env on the box and fill in.
# This file is read by the systemd unit (EnvironmentFile=).

# NATS URL the agent connects to. Use the region-local server.
#   tls://   for a direct TLS connection
#   ws(s)://  to ride the public WebSocket gateway
NATS_URL=tls://nats.subscribers.chat:4222

# Per-node credential file. Each box gets its OWN .creds, scoped to only this
# node's subjects (node.<id>.>). Never share one credential across boxes.
NATS_CREDS=/etc/node-agent/node.creds

# Stable, simple slug for this box. Used as the KV key and the subject token,
# so keep it to [A-Za-z0-9_-] (e.g. jp1, au2, sg1). Defaults to the hostname.
NODE_ID=jp1

# Optional region label, surfaced in the heartbeat document.
NODE_REGION=japan

# Optional overrides (defaults shown):
# NODES_KV_BUCKET=nodes
# HEARTBEAT_INTERVAL=15s
